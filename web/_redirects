/home                     /gearsh-app.html 200
/discover                 /gearsh-app.html 200
/discover/*               /gearsh-app.html 200
/profile                  /gearsh-app.html 200
/profile/*                /gearsh-app.html 200
/profile-settings         /gearsh-app.html 200
/edit-profile             /gearsh-app.html 200
/dashboard/*              /gearsh-app.html 200
/manager                  /gearsh-app.html 200
/booking/*                /gearsh-app.html 200
/book/*                   /book-gig?artist=:splat 200
/artist/*                 /gearsh-app.html 200
# /artists and /search served via Cloudflare Pretty URLs from artists.html /
# search.html. Do NOT add explicit rewrite rules — they will trigger the same
# 308 loop documented at the top of this file.
/category/*               /gearsh-app.html 200
/gigs                     /gearsh-app.html 200
/cart                     /gearsh-app.html 200
/cart/*                   /gearsh-app.html 200
/messages                 /gearsh-app.html 200
/bookings                 /gearsh-app.html 200
/my-bookings              /gearsh-app.html 200
/saved-artists            /gearsh-app.html 200
/forgot-password          /gearsh-app.html 200
/reset-password           /gearsh-app.html 200
/help                     /gearsh-app.html 200
/faq                      /gearsh-app.html 200
/settings                 /gearsh-app.html 200
# NOTE: do NOT add rewrite rules like `/terms /terms.html 200`.
# Cloudflare Pages' Pretty URLs auto-serves /terms from terms.html, and an
# explicit rewrite causes a 308 redirect loop (Pretty URLs strips .html each
# time the rewrite serves terms.html). The same applies to /privacy and
# /login (see comment at the top of this file).
/privacy-policy           /privacy 301

# Tonight — shareable shortlink to today's featured genre. search-page.js
# reads ?spotlight=tonight and pre-fills the genre filter from
# day-genre-schedule.js so the same URL works every night of the week.
/tonight                  /search?spotlight=tonight 302

