  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0b0b0f;
      --surface: #13131a;
      --border: #1e1e2e;
      --gold: #c9a84c;
      --gold-dim: #8a6e30;
      --text: #e8e6df;
      --muted: #7a7870;
      --accent: #d4a843;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      line-height: 1.75;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.6;
    }

    header {
      position: relative;
      z-index: 1;
      border-bottom: 1px solid var(--border);
      padding: 2rem 0 0;
      overflow: hidden;
    }

    .header-inner {
      max-width: 780px;
      margin: 0 auto;
      padding: 0 2rem 2.5rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
      margin-bottom: 2.5rem;
    }
    .back-link:hover { color: var(--gold); }
    .back-link svg { width: 14px; height: 14px; }

    .wordmark {
      font-family: 'Syne', sans-serif;
      font-size: 0.85rem;
      font-weight: 800;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.2rem;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-bottom: 1rem;
    }

    .meta {
      font-size: 0.82rem;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    .legal-notice {
      margin-top: 1.6rem;
      padding: 0.9rem 1.1rem;
      background: rgba(201, 168, 76, 0.07);
      border-left: 2px solid var(--gold-dim);
      border-radius: 2px;
      font-size: 0.82rem;
      color: #a09060;
      font-style: italic;
    }

    nav.toc {
      position: relative;
      z-index: 1;
      max-width: 780px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
      border-bottom: 1px solid var(--border);
    }

    .toc-label {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    .toc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0.3rem 1.5rem;
    }

    .toc-grid a {
      font-size: 0.83rem;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }
    .toc-grid a:hover { color: var(--gold); }
    .toc-grid a .num {
      font-family: 'Syne', sans-serif;
      font-size: 0.7rem;
      color: var(--gold-dim);
      min-width: 1.6rem;
    }

    main {
      position: relative;
      z-index: 1;
      max-width: 780px;
      margin: 0 auto;
      padding: 4rem 2rem 6rem;
    }

    section {
      margin-bottom: 4rem;
      opacity: 0;
      transform: translateY(18px);
      animation: fadeUp 0.5s ease forwards;
    }

    section:nth-child(1)  { animation-delay: 0.05s; }
    section:nth-child(2)  { animation-delay: 0.10s; }
    section:nth-child(3)  { animation-delay: 0.15s; }
    section:nth-child(4)  { animation-delay: 0.20s; }
    section:nth-child(5)  { animation-delay: 0.25s; }
    section:nth-child(6)  { animation-delay: 0.30s; }

    @keyframes fadeUp {
      to { opacity: 1; transform: none; }
    }

    .section-header {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 1.2rem;
      padding-bottom: 0.8rem;
      border-bottom: 1px solid var(--border);
    }

    .section-num {
      font-family: 'Syne', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--gold-dim);
      text-transform: uppercase;
      min-width: 2rem;
    }

    h2 {
      font-family: 'Syne', sans-serif;
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: 0.01em;
      color: var(--text);
    }

    h3 {
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--gold);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin: 1.6rem 0 0.7rem;
    }

    h4 {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--text);
      letter-spacing: 0.04em;
      margin: 1.2rem 0 0.5rem;
    }

    p {
      font-size: 0.93rem;
      color: #c8c4ba;
      margin-bottom: 0.8rem;
    }

    ul {
      list-style: none;
      margin: 0.4rem 0 0.8rem;
      padding: 0;
    }

    ul li {
      font-size: 0.93rem;
      color: #c8c4ba;
      padding: 0.35rem 0 0.35rem 1.4rem;
      position: relative;
      border-bottom: 1px solid rgba(255,255,255,0.03);
    }

    ul li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--gold-dim);
      font-size: 0.75rem;
    }

    ul li strong { color: var(--text); font-weight: 500; }

    /* Nested sub-lists */
    ul ul {
      margin: 0.4rem 0 0.2rem 1rem;
      border-left: 1px solid var(--border);
      padding-left: 0.8rem;
    }
    ul ul li::before { content: '·'; color: var(--gold-dim); }

    .note {
      margin-top: 1rem;
      padding: 0.75rem 1rem;
      background: rgba(255,255,255,0.03);
      border-left: 2px solid var(--border);
      border-radius: 2px;
      font-size: 0.83rem;
      color: var(--muted);
      font-style: italic;
    }

    .highlight-box {
      margin-top: 1rem;
      padding: 0.9rem 1.1rem;
      background: rgba(201, 168, 76, 0.06);
      border: 1px solid rgba(201, 168, 76, 0.15);
      border-radius: 4px;
      font-size: 0.85rem;
      color: #b09050;
      font-weight: 500;
    }

    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      max-width: 780px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer-brand {
      font-family: 'Syne', sans-serif;
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold-dim);
    }

    .footer-links {
      display: flex;
      gap: 1.5rem;
    }

    .footer-links a {
      font-size: 0.78rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--gold); }

    #progress {
      position: fixed;
      top: 0; left: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--gold-dim), var(--gold));
      width: 0%;
      z-index: 100;
      transition: width 0.1s linear;
    }

    @media (max-width: 600px) {
      h1 { font-size: 1.9rem; }
      .toc-grid { grid-template-columns: 1fr; }
      footer { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

<div id="progress"></div>

<header>
  <div class="header-inner">
    <a href="/" class="back-link">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M10 12L6 8l4-4"/>
      </svg>
      Back to Gearsh
    </a>
    <div class="wordmark">Gearsh</div>
    <h1>Privacy Policy</h1>
    <p class="meta">POPIA Compliant &nbsp;·&nbsp; South African Law Applies</p>
    <div class="legal-notice">
      Legal Notice: This Privacy Policy explains how Gearsh collects, uses, shares, and protects personal information in compliance with the Protection of Personal Information Act (POPIA) and other applicable data protection laws.
    </div>
  </div>
</header>

<nav class="toc" aria-label="Table of contents">
  <div class="toc-label">Contents</div>
  <div class="toc-grid">
